# ——— API (Neon / PostgreSQL) — ne jamais commiter le fichier .env
# Ce fichier doit s’appeler .env et être à la RACINE du projet (à côté de package.json),
# pas dans server/, pour que « npm run db:setup » / « db:migrate » le chargent.
#
# Exemple d’URL Neon (copie depuis le dashboard : Connection string, base « neondb »).
# Si node-pg échoue, essayez l’URL sans channel_binding= ; gardez sslmode=require.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Clé de signature des JWT (générer une chaîne longue aléatoire)
JWT_SECRET=changez-moi-vers-une-valeur-longue-secrete

# Origines autorisées pour CORS (séparées par des virgules). En prod : URL du site.
# CORS_ORIGINS=https://itelec-charge.be,https://www.itelec-charge.be

PORT=3001

# Limite corps JSON API (défaut 2mb)
# JSON_BODY_LIMIT=2mb

# Seed démo : désactivé en production sauf initialisation explicite
# ALLOW_DEMO_SEED=true
# DEMO_SEED_PASSWORD=mot-de-passe-demo-fort-et-unique

# URL publique du site (SEO, sitemap, liens canoniques)
# VITE_SITE_URL=https://itelec-charge.be
# VITE_CONTACT_PHONE=+32 …
# En prod (site et API sur des origines différentes), ex. : VITE_API_BASE=https://api.votredomaine.com
# VITE_API_BASE=

# Formulaire devis (site vitrine → POST /api/public/devis-request, même SMTP que les devis)
# Boîte qui reçoit les demandes (défaut : MAIL_REPLY_TO ou hello@itelec-charge.be)
# DEVIS_REQUEST_TO=hello@itelec-charge.be
# commercial_id des dossiers créés depuis le site (défaut : site)
# DEVIS_REQUEST_COMMERCIAL_ID=site
# Secours front uniquement si SMTP indisponible :
# VITE_WEB3FORMS_ACCESS_KEY=
# VITE_CONTACT_EMAIL=hello@itelec-charge.be
# VITE_LINKEDIN_URL=https://www.linkedin.com/company/…

# ——— Envoi e-mails (devis client) — Hostinger / boîte professionnelle
# MX itelec-charge.be → Hostinger : smtp.hostinger.com, port 587, TLS (SMTP_SECURE=false)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=hello@votredomaine.be
# SMTP_PASS=
# MAIL_FROM=Itelec Charge <hello@votredomaine.be>
# Lien « Voir mon devis » dans l’e-mail (/devis-signer/…) — votre site React, pas Hostinger hPanel
# Développement local (pnpm run dev) : http://localhost:5173 (forcé auto si NODE_ENV ≠ production)
# APP_PUBLIC_URL=http://localhost:5173
# Production : APP_PUBLIC_URL=https://itelec-charge.be
# Forcer l’URL prod dans les mails même en local : APP_USE_PRODUCTION_LINKS=true
# Taux TVA devis (défaut 21 %). Ex. : QUOTE_VAT_RATE=0.21 ou QUOTE_VAT_RATE=21
# QUOTE_VAT_RATE=0.21
# URL des CGV (sinon /conditions-generales sur APP_PUBLIC_URL)
# APP_CGV_URL=https://itelec-charge.be/conditions-generales
# En prod, si l’API est sur un autre domaine : VITE_API_BASE=https://api.itelec-charge.be
# (sinon laisser VITE_API_BASE vide si /api est sur le même domaine)
# MAIL_REPLY_TO=hello@votredomaine.be
# COMPANY_LEGAL_NAME=Itelec Charge
# COMPANY_ADDRESS=Rue du Bosquet 19, 6181 Gouy-lez-Pieton
# COMPANY_PHONE=+32 …
# COMPANY_VAT=BE0…

# ——— Stripe (paiements / abonnements) — mode test : clés pk_test_ / sk_test_ depuis le dashboard Stripe
# Clé secrète : serveur uniquement, jamais dans le front ni dans Git
# STRIPE_SECRET_KEY=sk_test_…
# Clé publiable : front (Vite) et/ou serveur pour GET /api/stripe/config
# STRIPE_PUBLISHABLE_KEY=pk_test_…
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_…
# Produits / prix (npm run stripe:setup les crée en test et affiche les IDs)
# STRIPE_PRODUCT_ID=prod_…
# STRIPE_PRICE_SUBSCRIPTION_PHASE1=price_…   # 59 €/mois (phase initiale)
# STRIPE_PRICE_SUBSCRIPTION_PHASE2=price_…   # 35 €/mois (après 48 mois)
# Webhook : en local → stripe listen --forward-to localhost:3001/api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=whsec_…

