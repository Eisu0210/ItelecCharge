{
  "name": "itelec-charge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "db:setup": "tsx server/db-setup.ts",
    "db:migrate": "tsx server/migrate.ts",
    "db:check": "tsx server/check-db.ts",
    "smtp:verify": "tsx server/smtp-verify.ts",
    "stripe:verify": "tsx server/stripe-verify.ts",
    "stripe:setup": "tsx server/stripe-setup.ts",
    "db:seed": "tsx server/seed.ts",
    "build": "tsx scripts/generate-sitemap.ts && tsc --noEmit && vite build && tsx scripts/prerender.ts",
    "build:no-prerender": "tsx scripts/generate-sitemap.ts && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.0",
    "vite": "^6.3.0"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489"
}
